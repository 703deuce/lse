# ── Google Maps JavaScript API (scan maps UI) ─────────────────
# Coolify: set MAPS to your Maps JavaScript API key.
# Restrict the key by HTTP referrer in Google Cloud Console.
MAPS=
# Optional aliases (also supported):
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_MAPS=
# GOOGLE_MAPS_API_KEY=

# ── Job cron / webhooks (required in production) ──────────────
# Coolify on Hetzner: schedule a cron/scheduled task every minute:
#   curl -fsS -X POST -H "Authorization: Bearer $CRON_SECRET" https://YOUR_DOMAIN/api/jobs/process
# See docs/COOLIFY_CRON_CAMPAIGNS.md
CRON_SECRET=
DATAFORSEO_WEBHOOK_SECRET=
BREVO_INBOUND_WEBHOOK_SECRET=

# Scan lease TTL for mid-flight reclaim / resume (default 5 minutes)
# SCAN_LEASE_MS=300000

# Provider HTTP timeouts / circuit breaker (optional)
# PROVIDER_TIMEOUT_MS=45000
# PROVIDER_TIMEOUT_MS_BRIGHTDATA=45000
# PROVIDER_CIRCUIT_THRESHOLD=5
# PROVIDER_CIRCUIT_COOLDOWN_MS=60000
# PROVIDER_COST_USD_BRIGHTDATA=0.0015

# ── Supabase (required for real data) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Dev auth bypass (local UI work only — do NOT enable in production) ──
# Skips login middleware and uses mock auth context in development.
DEV_BYPASS_AUTH=true
NEXT_PUBLIC_DEV_BYPASS_AUTH=true

# Use in-memory mock IDs instead of creating/fetching org rows in Supabase.
DEV_MOCK_AUTH=true

# Allow API routes to accept the preview business without DB ownership checks.
DEV_BYPASS_BUSINESS_ACCESS=true

# Return mock Reviews page JSON for the preview business ID below.
DEV_USE_MOCK_DATA=true
DEV_BUSINESS_ID=preview

# Optional fixed IDs (otherwise defaults are used)
# DEV_USER_ID=00000000-0000-0000-0000-000000000001
# DEV_ORG_ID=00000000-0000-0000-0000-000000000002
