# ── Google Maps JavaScript API (scan maps UI) ─────────────────
# Coolify: set MAPS to your Maps JavaScript API key (runtime is fine).
# The server injects it into the browser via layout /api/maps/config.
# Restrict the key by HTTP referrer in Google Cloud Console
# (e.g. https://app.localseoexpress.com/*).
MAPS=
# Optional aliases (also supported):
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_MAPS=
# GOOGLE_MAPS_API_KEY=
#
# PDF / map image exports use Google Maps Static API from the worker (server-side).
# HTTP-referrer browser keys return 403 there. Either:
#   1) Enable "Maps Static API" and allow the worker IP on MAPS, or
#   2) Set a separate server key (IP-restricted or unrestricted):
# GOOGLE_MAPS_STATIC_API_KEY=
# STATIC_MAPS_API_KEY=
# Put the static key on the report / worker:all service, then redeploy.

# ── Public app URL (production Coolify / Traefik) ─────────────
# Must match the browser Origin exactly (scheme + host). Used for CSRF allowlist,
# webhooks, and absolute links. Set all three on the main web app, then redeploy.
APP_URL=https://app.localseoexpress.com
NEXT_PUBLIC_APP_URL=https://app.localseoexpress.com
ALLOWED_ORIGINS=https://app.localseoexpress.com
# Do NOT use www., http://, preview domains, or the container hostname here.

# ── Job cron / webhooks (required in production) ──────────────
# Coolify scheduled task every minute — see docs/PRODUCTION_WEBHOOKS.md
#   curl -fsS -X POST -H "Authorization: Bearer $CRON_SECRET" https://app.localseoexpress.com/api/jobs/process
CRON_SECRET=
DATAFORSEO_WEBHOOK_SECRET=
# Brevo transactional email (Quick Send + messaging worker email-send)
# Required on BOTH the web app and `npm run worker:messaging`.
BREVO_API_KEY=
REVIEW_REQUEST_FROM_EMAIL=
REVIEW_REQUEST_FROM_NAME=Maps Growth Reviews
# Sender must be verified in the Brevo dashboard.
BREVO_INBOUND_WEBHOOK_SECRET=
BREVO_EVENTS_WEBHOOK_SECRET=
TWILIO_WEBHOOK_URL=https://app.localseoexpress.com/api/webhooks/twilio/sms
TWILIO_STATUS_CALLBACK_URL=https://app.localseoexpress.com/api/webhooks/twilio/sms
# Account Auth Token (console) — used to validate X-Twilio-Signature
# TWILIO_ACCOUNT_AUTH_TOKEN=
# Optional: node scripts/configure-production-webhooks.mjs
REVIEW_REQUEST_REPLY_DOMAIN=

# Scan lease TTL for mid-flight reclaim / resume (default 5 minutes)
# SCAN_LEASE_MS=300000

# ── Platform execution (see docs/PLATFORM_ARCHITECTURE.md) ──
# QUEUE_DRIVER=database
# QUEUE_DRIVER=bullmq
# CACHE_DRIVER=none
# CACHE_DRIVER=memory
# CACHE_DRIVER=redis
# LOCK_DRIVER=memory
# LOCK_DRIVER=redis
# REDIS_URL=redis://:password@redis:6379
# BullMQ Redis key prefix only (NOT part of the queue name). Do not use ":".
# QUEUE_PREFIX=lse
# REALTIME_TRANSPORT=auto
# Bright Data capacity (shared across all Maps workers via Redis when REDIS_URL set)
# BRIGHTDATA_GLOBAL_START_RATE_PER_SEC=100
# BRIGHTDATA_GLOBAL_MAX_IN_FLIGHT=250
# Per-scan wave / local concurrency (default 100). Concurrent scans share the global limiter.
# BRIGHTDATA_FAIR_CHUNK_SIZE=100
# BRIGHTDATA_GRID_BATCH_SIZE=100
# MAX_ACTIVE_MAPS_SCANS_PER_ORG=3
# MAX_QUEUED_MAPS_SCANS_PER_ORG=10
# How many Maps *jobs* one worker runs at once (each job can fan out ≤100 cells):
# QUEUE_CONCURRENCY_MAPS_SCAN=2
# Messaging worker (npm run worker:messaging) — campaign drain + email/sms senders
# QUEUE_CONCURRENCY_REVIEW_CAMPAIGN=2
# QUEUE_CONCURRENCY_EMAIL_SEND=15
# QUEUE_CONCURRENCY_SMS_SEND=10
# Twilio / Brevo global throttles (Redis-backed when REDIS_URL set)
# TWILIO_GLOBAL_START_RATE_PER_SEC=5
# TWILIO_GLOBAL_MAX_IN_FLIGHT=20
# BREVO_GLOBAL_START_RATE_PER_SEC=20
# BREVO_GLOBAL_MAX_IN_FLIGHT=40

# Provider HTTP timeouts / circuit breaker (optional)
# PROVIDER_TIMEOUT_MS=45000
# PROVIDER_TIMEOUT_MS_BRIGHTDATA=45000
# PROVIDER_CIRCUIT_THRESHOLD=5
# PROVIDER_CIRCUIT_COOLDOWN_MS=60000
# PROVIDER_COST_USD_BRIGHTDATA=0.0015

# ── Supabase (required for real data) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Dev auth bypass (local UI work only — do NOT enable in production) ──
# Skips login middleware and uses mock auth context in development.
DEV_BYPASS_AUTH=true
NEXT_PUBLIC_DEV_BYPASS_AUTH=true

# Use in-memory mock IDs instead of creating/fetching org rows in Supabase.
DEV_MOCK_AUTH=true

# Allow API routes to accept the preview business without DB ownership checks.
DEV_BYPASS_BUSINESS_ACCESS=true

# Return mock Reviews page JSON for the preview business ID below.
DEV_USE_MOCK_DATA=true
DEV_BUSINESS_ID=preview

# Optional fixed IDs (otherwise defaults are used)
# DEV_USER_ID=00000000-0000-0000-0000-000000000001
# DEV_ORG_ID=00000000-0000-0000-0000-000000000002
