# Local SEO Express – Apache config for shared hosting
# Clean URLs: /about/ works without /about/index.html in the browser

DirectoryIndex index.html index.htm
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Canonical host: always https://localseoexpress.com
  # Force HTTPS and non-www in one permanent redirect
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} !^localseoexpress\.com$ [NC]
  RewriteRule ^ https://localseoexpress.com%{REQUEST_URI} [R=301,L,NE]

  # --- External redirects: hide index.html and .html from URLs ---

  # /index.html  ->  /
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L]

  # /folder/index.html  ->  /folder/
  RewriteCond %{THE_REQUEST} \s/+([^?\s]*/?)index\.html[\s?] [NC]
  RewriteRule ^(.+/)index\.html$ /$1 [R=301,L]

  # /page.html  ->  /page/
  RewriteCond %{THE_REQUEST} \s/+([^?\s]*?)\.html[\s?] [NC]
  RewriteRule ^(.+)\.html$ /$1/ [R=301,L]

  # --- Trailing slash: directories use /page/ not /page ---

  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [R=301,L]

  # --- Internal rewrites: serve files for clean URLs ---

  # /page/  ->  /page/index.html  (folder-per-page layout)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^(.+)/$ $1/index.html [L]

  # /page/  ->  /page.html  (flat-file fallback)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+)/$ $1.html [L]

  # /page  ->  /page/  when only the folder+index.html exists (no physical dir match yet)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^([^/]+)$ /$1/ [R=301,L]

  # /page  ->  /page/  when only page.html exists
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^([^/]+)$ /$1/ [R=301,L]
</IfModule>

# Enable compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Custom 404 page (create when ready)
# ErrorDocument 404 /404.html
